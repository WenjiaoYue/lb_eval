# config.env — Shared configuration for auto.sh unified pipeline
# Copy this file to config.env and fill in your values.
# This file should NOT be committed to git (add to .gitignore).

# ═══════════════════════════════════════════════════════════════════════
# HuggingFace — model upload (multi-token failover)
# ═══════════════════════════════════════════════════════════════════════
# Comma-separated HF tokens. auto.sh tries each in order until one succeeds.
HF_TOKENS=

# Comma-separated org/user names matching each token above.
# If fewer orgs than tokens, the last org is reused.
HF_UPLOAD_ORGS=LeaderboardModel1,LeaderboardModel2,LeaderboardModel3,LeaderboardModel4

# Local storage ledger for HF uploads.
# The script treats each account as this capacity and updates usage locally after
# each successful upload.
HF_ACCOUNT_CAPACITY_GB=1000
HF_USAGE_FILE=/root/leaderboard_Agent/tasks/lb_eval/auto_quant/hf_account_usage.json
HF_ACCOUNT_IDS=

# Shared ledger for multi-machine / multi-process coordination.
# Repo can be a HF dataset repo id like "org/hf-upload-ledger", a full URL, or a local git path.
HF_SHARED_LEDGER_ENABLED=true
HF_SHARED_LEDGER_REPO=${GIT_REPO:-}
HF_SHARED_LEDGER_TOKEN=
HF_SHARED_LEDGER_BRANCH=main
HF_SHARED_LEDGER_CLONE_DIR=
HF_SHARED_LEDGER_RESERVATION_TTL_SECONDS=7200
HF_SHARED_LEDGER_GIT_USER_NAME=hf-ledger-bot
HF_SHARED_LEDGER_GIT_USER_EMAIL=hf-ledger-bot@local

# GitHub upload for result artifacts.
GIT_TOKEN=
GIT_REPO=https://github.com/XuehaoSun/lb_eval.git
GIT_BRANCH=main
# If empty or missing, upload_results_github.py will clone automatically.
GIT_RESULTS_REPO_DIR=
GIT_RESULTS_CLONE_DIR=
GIT_USER_NAME=lkk12014402
GIT_USER_EMAIL=kaokao.lv@intel.com

# ═══════════════════════════════════════════════════════════════════════
# MiniMax API key (for openclaw agent inside container)
# ═══════════════════════════════════════════════════════════════════════
MINIMAX_API_KEY=

# ═══════════════════════════════════════════════════════════════════════
# Agent backend selection (fix-loop self-repair agent)
# ═══════════════════════════════════════════════════════════════════════
# Which agent the fix loop calls when a phase fails:
#   openclaw → OpenClaw agent (default, uses MiniMax backend above)
#   copilot  → GitHub Copilot CLI (`copilot`, uses GitHub's own model backend)
# AGENT_BACKEND=openclaw
# Per-call agent timeout in seconds (applies to whichever backend is selected).
AGENT_BACKEND=copilot
AGENT_TIMEOUT=600

# Two-agent bug-analysis flow: 1 = diagnoser agent then fixer agent; 0 = single agent.
MULTI_AGENT=0

# --- Hybrid escalation (cheap-first, escalate on hard cases) ---
# AGENT_ESCALATE=1 → use AGENT_PRIMARY for the first AGENT_ESCALATE_AFTER fix
# attempts (cheap, routine errors), then switch to AGENT_ESCALATED for the harder
# remaining attempts. Also applies to failure diagnosis (analyze_failures.py):
# tries PRIMARY first, escalates to ESCALATED if the diagnosis is inconclusive.
# When AGENT_ESCALATE=0, the single AGENT_BACKEND above is used.
AGENT_ESCALATE=1
AGENT_PRIMARY=openclaw
AGENT_ESCALATED=copilot
AGENT_ESCALATE_AFTER=2

# --- Bug-fix patch capture (both backends) ---
# The fix loop records a unified diff of what the agent changed into each lesson.
# Colon-separated dirs to watch. Leave empty to auto-detect (auto-round source,
# phase scripts, run output dir). Add the HF cache dir here to capture edits to
# custom model code.
# PATCH_CAPTURE_DIRS=/root/auto-round:/root/.cache/huggingface
# Path to a local auto-round git checkout, if you install it editable (improves
# patch capture of auto-round source edits).
# AUTO_ROUND_SRC_DIR=/root/auto-round

# --- Copilot CLI options (only used when AGENT_BACKEND=copilot) ---
# Binary name/path for the Copilot CLI.
COPILOT_BIN=copilot
# GitHub token for headless auth. Prefer exporting it from the shell/CI secret
# store instead of committing it here. Must be a fine-grained PAT (github_pat_...)
# with the "Copilot Requests" permission (classic ghp_ tokens are NOT supported).
# Leave empty to rely on a prior interactive `copilot login`.
COPILOT_GITHUB_TOKEN=
# Optional model override; leave empty to use Copilot's default (auto/sonnet).
COPILOT_MODEL=
# Tool-permission args passed to the CLI (autonomous execution by default).
COPILOT_TOOL_ARGS=--allow-all-tools

# ═══════════════════════════════════════════════════════════════════════
# Network proxy (leave empty if not behind corporate proxy)
# ═══════════════════════════════════════════════════════════════════════
# HTTP_PROXY=http://proxy.ims.intel.com:911
# HTTPS_PROXY=http://proxy.ims.intel.com:911

# ═══════════════════════════════════════════════════════════════════════
# Docker settings
# ═══════════════════════════════════════════════════════════════════════
IMAGE_NAME=cuda-openclaw:local

# ═══════════════════════════════════════════════════════════════════════
# Pipeline defaults (can be overridden by JSON input)
# ═══════════════════════════════════════════════════════════════════════
# METHOD controls quantization iters:
#   RTN    → iters=0 (fast, no calibration tuning)
#   TUNING → iters=200 (calibration-based optimization)
METHOD=RTN
EXPORT_FORMAT=auto_round
DEVICE=cuda
DEVICE_INDEX=0
TIMEOUT=36000
EVAL_TASKS=piqa,mmlu,hellaswag
EVAL_BATCH_SIZE=auto

# OpenClaw paths
# Leave OPENCLAW_WORKSPACE_DIR empty to auto-detect in this order:
# 1. /root/leaderboard_Agent/auto_quant/openclaw_home/workspace
# 2. /root/leaderboard_Agent/tasks/lb_eval/openclaw_config/workspace
# 3. /root/.openclaw/workspace
OPENCLAW_WORKSPACE_DIR=/root/.openclaw/workspace

# Session logs copied after each agent run. Keep the default unless your
# OpenClaw runtime writes session jsonl files elsewhere.
OPENCLAW_SESSIONS_DIR=/root/.openclaw/agents/main/sessions

# ═══════════════════════════════════════════════════════════════════════
# Host output directory — results are persisted here via volume mount
# ═══════════════════════════════════════════════════════════════════════
# Quantized model files are written under OUTPUT_DIR/<model>-<scheme>
#
# Runtime artifacts such as logs, prompts, request/session copies, summaries,
# and venvs are written under:
#   ${RUNTIME_OUTPUT_BASE_DIR:-${OUTPUT_DIR}/runs}/<model>-<scheme>
#
# Leave empty to use the default "<OUTPUT_DIR>/runs" directory.
RUNTIME_OUTPUT_BASE_DIR=

# ═══════════════════════════════════════════════════════════════════════
# HuggingFace cache directory (model/dataset downloads)
# ═══════════════════════════════════════════════════════════════════════
# By default HuggingFace downloads to ~/.cache/huggingface (i.e. /root/.cache),
# on the container's writable layer. On AWS B200 (local-agent) nodes, auto.sh
# automatically redirects the cache to /azure/hf_cache (a large mounted disk) so
# big model weights don't fill the container; all other hardware keeps the default.
#
# Leave empty for that automatic behavior. Set an absolute path here to force a
# specific cache location for ALL runs (overrides the B200 auto-placement).
HF_HOME=

# ═══════════════════════════════════════════════════════════════════════
# lb_eval GitHub repo (for uploading results/status)
# Relative path from tasks/ dir, or absolute path.
# ═══════════════════════════════════════════════════════════════════════
LB_EVAL_REPO=lb_eval
